# gate-arb environment config
# Copy to .env and fill in values

# === Trading symbols ===
SPOT_SYMBOL=BTC_USDT
PERP_SYMBOL=BTC_USDT

# === Strategy parameters ===
# Entry spread threshold in % (e.g. 0.05 = 5bps)
ENTRY_SPREAD_PCT=0.05
# Max position size in USD
MAX_POSITION_USD=1000

# === Gate.io API (leave empty for paper mode) ===
GATE_API_KEY=
GATE_SECRET=

# === Mode ===
# Set to 'false' to enable live trading
PAPER_MODE=true

# === Network ===
GATE_WS_URL=wss://api.gateio.ws/ws/v4/
FRONTEND_PORT=8080
HEALTH_PORT=8081
